# PostgreSQL Datenbank Konfiguration
POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=familien_dashboard
POSTGRES_PORT=5432

# Flask Datenbank URL (muss mit den PostgreSQL-Werten oben übereinstimmen)
DATABASE_URL=postgresql://dashboard_user:change_me@localhost:5432/familien_dashboard

# JWT-Schlüssel — langen zufälligen String verwenden, z. B.: openssl rand -hex 32
JWT_SECRET_KEY=change_me

# OpenWeatherMap API-Key (https://openweathermap.org/api)
OPENWEATHER_API_KEY=change_me

# URL des Frontends (für CORS)
FRONTEND_URL=http://localhost:3000
